# Top-level deps for the persona-sandbox image (spec 12 T06 / R-12-3).
# Compile into a hash-verified ``requirements.txt`` via:
#
#   pip-compile --generate-hashes --output-file=requirements.txt requirements.in
#
# Versions are the D-12-2 / R-12-3 pinned snapshot for mid-2026. Re-resolve
# at build time and commit the resulting requirements.txt; the runtime
# refuses any wheel whose sha256 does not match (PyPA hash-mode).

# --- numerics + data analysis (Spec 17) ---
numpy==2.1.3
pandas==2.2.3
matplotlib==3.9.2

# --- spreadsheets + office documents (Spec 16) ---
openpyxl==3.1.5
python-docx==1.1.2
python-pptx==1.0.2
reportlab==4.2.5


  "components": {
    "schemas": {
      "AuthorPersonaRequest": {
        "properties": {
          "description": {
            "type": "string",
            "maxLength": 4000,
            "minLength": 1,
            "title": "Description"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": ["description"],
        "title": "AuthorPersonaRequest",
        "description": "LLM-assisted authoring from a natural-language description (\u00a75.1, \u00a76.3)."
      },
      "ChannelContext": {
        "properties": {
          "platform": {
            "type": "string",
            "title": "Platform"
          },
          "platform_user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Platform User Id"
          },
          "platform_chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Platform Chat Id"
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Metadata"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": ["platform"],
        "title": "ChannelContext",
        "description": "Opaque connector context passed through the chat endpoint (D-08-3).\n\nThe API stores this on the message row and never interprets it \u2014 ``platform``\nis a free-form string, NEVER an enum the API branches on. All connector logic\nlives in the future spec-12 connectors. Null/absent is the web-UI case."
      },
      "ConversationDetail": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "persona_id": {
            "type": "string",
            "title": "Persona Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/MessageView"
            },
            "type": "array",
            "title": "Messages"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "persona_id",
          "title",
          "messages",
          "created_at",
          "updated_at"
        ],
        "title": "ConversationDetail",
        "description": "Full conversation history."
      },
      "ConversationSummary": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "persona_id": {
            "type": "string",
            "title": "Persona Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": ["id", "persona_id", "title", "created_at", "updated_at"],
        "title": "ConversationSummary",
        "description": "A conversation in a list view."
      },

# Open Persona — web app environment (spec 09). Copy to `.env.local` and fill in.
# Never commit real secrets; `.env*` is gitignored (this template is the exception).

# --- API (spec 08) ---
# Base URL of the persona-api. No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Auth: Clerk (D-09-2) ---
# From the Clerk dashboard. The publishable key is exposed to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# The Clerk JWT template whose token is sent as `Authorization: Bearer` to the API.
# The template MUST set `aud` to match the API's PERSONA_API_JWT_AUDIENCE, and the
# API must set PERSONA_API_JWT_ALGORITHMS=RS256 + PERSONA_API_JWT_PUBLIC_KEY=<Clerk PEM>.
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=persona-api
# Auth routing.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/personas
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/personas

# Open Persona — production env-var manifest (Spec 11, T10)
# Copy to `.env.production` on the VPS and fill in. Never commit secrets.
# Every variable the system reads at runtime is documented here.

# ---------- Database ----------
POSTGRES_PASSWORD=                        # the `persona` superuser password (used by Compose)
PERSONA_APP_DB_PASSWORD=                  # the non-superuser `persona_app` RLS role password
# DATABASE_URL / APP_DATABASE_URL are composed by docker-compose.production.yml from the above.

# ---------- Auth (Clerk RS256) ----------
PERSONA_API_JWT_ALGORITHMS=RS256
PERSONA_API_JWT_AUDIENCE=persona-api      # T07 fix for the open spec-08 MEDIUM (D-08-4) — REQUIRED
PERSONA_API_JWT_PUBLIC_KEY=               # paste the Clerk dashboard public PEM (multi-line OK with `"..."`)

# ---------- Model providers (per tier) ----------
# v0.1 demo wires all three tiers to DeepSeek (cheap, soak-proven for tools).
# Switch FRONTIER to Anthropic Sonnet for the screencast backup take.
PERSONA_FRONTIER_PROVIDER=deepseek
PERSONA_FRONTIER_MODEL=deepseek-chat
PERSONA_FRONTIER_API_KEY=                 # DeepSeek API key
PERSONA_MID_PROVIDER=deepseek
PERSONA_MID_MODEL=deepseek-chat
PERSONA_MID_API_KEY=                      # DeepSeek API key
PERSONA_SMALL_PROVIDER=deepseek
PERSONA_SMALL_MODEL=deepseek-chat
PERSONA_SMALL_API_KEY=                    # DeepSeek API key
PERSONA_PROVIDER=deepseek                 # fallback used by the title builder and standalone calls
PERSONA_MODEL=deepseek-chat
PERSONA_API_KEY=                          # DeepSeek API key (fallback)

# Optional — Anthropic backup model (rehearsed; one-env-change switch, D-11-9)
# Uncomment to make Sonnet the frontier instead.
# PERSONA_FRONTIER_PROVIDER=anthropic
# PERSONA_FRONTIER_MODEL=claude-sonnet-4-6
# PERSONA_FRONTIER_API_KEY=

# ---------- Web search (for Astrid/Kai web_research) ----------
# Supported providers: `tavily` (recommended, free 1k/mo, no CC) or `brave`
# (2k/mo, CC required). Tavily is the launch default — wired in T07b follow-up.
PERSONA_WEB_SEARCH_PROVIDER=tavily
PERSONA_WEB_SEARCH_API_KEY=               # Tavily key (tvly-...) or Brave key

# ---------- CORS (the Vercel origin must be here) ----------
PERSONA_API_CORS_ORIGINS=https://openpersona.dev,https://www.openpersona.dev

# ---------- Memory + audit roots ----------
PERSONA_CHROMA_PATH=/var/lib/persona/chroma   # Chroma path (unused when the postgres backend is wired, but read at config)
PERSONA_AUDIT_ROOT=/var/lib/persona/audit
PERSONA_TURNLOG_PATH=/var/lib/persona/turnlogs

# ---------- Logging ----------
PERSONA_LOG_LEVEL=INFO

# Copy to .env and fill in your values. Never commit .env.
#
# Spec 02 (model backends): persona-core reads PERSONA_PROVIDER + PERSONA_API_KEY
# + PERSONA_MODEL (+ optional PERSONA_BASE_URL) for the default backend.
# Optional per-tier overrides land in spec 05; the keys below reserve the env var
# names so the wiring is consistent across specs.

# ============================================================================
# Open-core edition (Spec 33) — the master switch (api + web + voice read it)
# ============================================================================
# PERSONA_EDITION=community (the default) runs the whole product locally with
# NO auth wall, NO credits, and NO Postgres/Docker — persistence is a SQLite
# file + Chroma. You only need a model API key (above). Leave it unset for the
# zero-infra self-host.
#
# PERSONA_EDITION=cloud is the commercial hosting path: Clerk auth, multi-tenant
# Postgres RLS, and metered credits (set DATABASE_URL/APP_DATABASE_URL + the JWT
# + Clerk vars below). The owner's deploy MUST set this — see MAINTENANCE.md.
# PERSONA_EDITION=community
#
# Community persistence paths (optional overrides; sensible cwd defaults):
# PERSONA_API_COMMUNITY_DB_PATH=./.persona_community.db
# PERSONA_API_COMMUNITY_MEMORY_PATH=./.persona_chroma
#
# Safety guard (D-33-4): community is single-user-local by intent. The API
# REFUSES to start no-auth on a non-loopback bind unless you explicitly opt in.
# Only set this if you understand the instance will be OPEN + UNAUTHENTICATED.
# PERSONA_ALLOW_PUBLIC_NOAUTH=1
# PERSONA_API_HOST=127.0.0.1

# --- Default backend (used by CLI and as the frontier tier in spec 05) ---
PERSONA_PROVIDER=anthropic
PERSONA_MODEL=claude-sonnet-4-6
PERSONA_API_KEY=sk-ant-...

# Optional: override the provider's default base URL (proxy, self-hosted, or a
# new provider not in the OpenAI-compat table).
# PERSONA_BASE_URL=https://my-proxy.example/v1/

# Optional: per-call HTTP timeout (seconds). Default 60. (D-02-3)
# PERSONA_REQUEST_TIMEOUT_S=60

# Optional: have the CLI load .env into os.environ on startup (D-02-4).
# Library code never touches .env autoload; only the CLI sets this.
# PERSONA_DOTENV_LOAD=1

# --- Per-provider keys (used when a tier picks a non-default provider) ---
# (Provider-key env vars are read by spec 05's router, not by spec 02.)
# PERSONA_ANTHROPIC_API_KEY=sk-ant-...
# PERSONA_OPENAI_API_KEY=sk-...
# PERSONA_DEEPSEEK_API_KEY=sk-...
# PERSONA_GROQ_API_KEY=gsk_...
# PERSONA_TOGETHER_API_KEY=...
# PERSONA_OLLAMA_BASE_URL=http://localhost:11434

# --- NVIDIA (Spec 20) ---
# PERSONA_NVIDIA_API_KEY=nvapi-...
# PERSONA_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/   # optional override
#
# NOTE: NVIDIA's hosted catalog at integrate.api.nvidia.com is "for prototyping,
# research, development and testing purposes only" per NIM ToS. Production-tier
# traffic (real end-users / business transactions) requires NVIDIA AI Enterprise
# (~$4,500/GPU/year or ~$1/GPU-hour cloud) OR routing production traffic through
# a different provider for production traffic (set as primary in PERSONA_<TIER>_MODELS,
# demote NVIDIA to fallback-only slot).

# --- OpenRouter (Spec 22) ---
# Single key unlocks 300+ aggregated models (Anthropic, OpenAI, Meta, Google,
# DeepSeek, NVIDIA, ...) via one OpenAI-compatible surface. Native model names
# are already <provider>/<model> slash-format, so OpenRouter slots into the
# PERSONA_<TIER>_MODELS cross-provider lists below unchanged (D-22-3 + D-20-13).
# PERSONA_OPENROUTER_API_KEY=sk-or-v1-...
# PERSONA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/   # optional override
#
# Subscription mode auto-detects at startup via GET /api/v1/key (D-22-3): the
# key's is_free_tier flag selects free-mode (only :free models usable) vs
# paid-mode (full catalog). Force it (skip the probe) with:
# PERSONA_OPENROUTER_SUBSCRIPTION_MODE=free   # or "paid" (D-22-7 escape hatch)
#
# OpenRouter :free examples (verified 2026-06-10; the 2025 roster — DeepSeek-R1,
# Llama-4, Qwen3-235B, Gemini-Flash :free — is DELISTED). Free-tier limits:
# 20 req/min; 50 req/day (<$10 lifetime credits) or 1000/day (>=$10). Account-wide,
# no SLA, roster churns without notice — fallback/dev slots only; pair with a
# non-OpenRouter primary (e.g. NVIDIA NIM) for the daily-cap mitigation (D-22-2 + F-position).
# PERSONA_FRONTIER_MODELS=openrouter/nvidia/nemotron-3-ultra-550b-a55b:free
# PERSONA_MID_MODELS=openrouter/nvidia/nemotron-3-super-120b-a12b:free,openrouter/openai/gpt-oss-120b:free
# PERSONA_MID_MODELS=openrouter/google/gemma-4-31b-it:free   # vision (image+video) + tools alternative
# PERSONA_SMALL_MODELS=openrouter/nvidia/nemotron-nano-9b-v2:free
#
# Image generation (paid-mode only; zero :free image models exist on OpenRouter):
# PERSONA_IMAGEGEN_MODELS=openrouter/google/gemini-2.5-flash-image   # ~$0.039/image (D-22-8 + acceptance #2)

# --- Intelligent routing (Spec 23) ---
# Metadata-driven model selection WITHIN a tier (cost / quality / latency /
# capability) is configured PER-PERSONA in the persona YAML, NOT via env vars —
# it is opt-in (default off) so existing personas route unchanged:
#
#   routing:
#     intelligent:
#       enabled: true                 # default false (v0.2 opt-in)
#       weights: { cost: 0.4, quality: 0.5, latency: 0.1 }   # capability is a hard gate
#       fallback_to_rule_based_on_miss: true                 # degrade on metadata miss
#     budget:
#       max_cents_per_turn: 5          # HARD cap → BudgetExceededError if nothing fits
#       max_cents_per_session: 100     # SOFT cap → re-weights toward cost as it nears
#       # max_cents_per_day: 500       # NOT YET ENFORCED — setting it FAILS LOUD at
#       #                              # startup (no cross-session store; D-23-7).
#
# The only env lever Spec 23 adds is the metadata source: the static per-provider
# tables in persona-core are always available (authoritative, offline); setting
# PERSONA_OPENROUTER_API_KEY (above) additionally enables the OpenRouter catalog
# as the broad-coverage fallback for models not in the static tables
# (D-23-X-resolver-precedence: static wins on overlap).

# --- Tier overrides (spec 05 router; read by TierRegistry) ---
# The runtime routes each turn to frontier / mid / small (architecture §5.3).
# Fallback (D-05-3): an unconfigured tier falls back small → mid → frontier.
# If NONE of the tier triples below are set, the registry builds a single
# backend from PERSONA_PROVIDER/PERSONA_MODEL/PERSONA_API_KEY above and serves
# it for all three tiers. If nothing resolves, TierNotConfiguredError (fail-fast).
PERSONA_FRONTIER_PROVIDER=anthropic
PERSONA_FRONTIER_MODEL=claude-sonnet-4-6
PERSONA_FRONTIER_API_KEY=sk-ant-...

PERSONA_MID_PROVIDER=deepseek
PERSONA_MID_MODEL=deepseek-chat
PERSONA_MID_API_KEY=sk-...

PERSONA_SMALL_PROVIDER=groq
PERSONA_SMALL_MODEL=llama-3.1-8b-instant
PERSONA_SMALL_API_KEY=gsk_...

# --- Cross-provider tier MODELS lists (Spec 20; D-20-13 + D-20-17) ---
# Optional. When set, takes precedence over the per-tier PROVIDER+MODEL+API_KEY
# triplet above (case (c) emits INFO log; case (b) preserves backward-compat
# single-backend fast path).
#
# Format: <provider>/<model>,<provider>/<model>,...   (slash-separated; comma-CSV)
# Per-entry credentials resolved via PERSONA_<PROVIDER>_API_KEY +
# PERSONA_<PROVIDER>_BASE_URL (the per-provider block above).
#
# `local` and `ollama` are NOT permitted in MODELS lists (D-20-18 — use
# the single-backend fast path via PERSONA_<TIER>_PROVIDER instead).
#
# Examples:
# PERSONA_FRONTIER_MODELS=nvidia/nemotron-3-super-120b-a12b,anthropic/claude-sonnet-4-6,openai/gpt-4o
# PERSONA_MID_MODELS=nvidia/llama-3.3-nemotron-super-49b-v1.5,deepseek/deepseek-chat
# PERSONA_SMALL_MODELS=groq/llama-3.1-8b-instant,nvidia/llama-3.3-nemotron-super-49b-v1.5
# PERSONA_IMAGEGEN_MODELS=nvidia/flux.2-klein-4b,fal/flux-1.1-pro,openai/gpt-image-1
#
# When BOTH PERSONA_<TIER>_MODELS and PERSONA_<TIER>_PROVIDER+MODEL+API_KEY
# are set, MODELS wins and an INFO log identifies the ignored triplet vars
# (D-20-17 case (c) — operator-mid-migration aid).

# --- Per-tier router metadata (Spec 18 T04; Spec 20 T14 reasoning-capable) ---
# Optional. All six REQUIRED fields below must be set together for the
# TierRegistry to populate TierMetadata (UnifiedRouter Layer 2 reads it).
# Partial sets fall back to None (HeuristicRouter still routes the tier).
#
# # Required (set together):
# PERSONA_FRONTIER_COST_INPUT_PER_1K=1.5             # cents per 1k input tokens
# PERSONA_FRONTIER_COST_OUTPUT_PER_1K=7.5            # cents per 1k output tokens
# PERSONA_FRONTIER_FIRST_TOKEN_LATENCY_MS=600        # ms; EWMA-replaced after warm-up
# PERSONA_FRONTIER_THROUGHPUT_TOKENS_PER_SEC=30      # post-first-token throughput
# PERSONA_FRONTIER_CONTEXT_WINDOW=1000000            # tokens
# PERSONA_FRONTIER_TOOL_STRENGTH=strong              # weak | medium | strong
#
# # Optional (Spec 20 T14 additive):
# PERSONA_FRONTIER_REASONING_CAPABLE=true            # D-18-5 quality-proxy boost
#                                                     # on hard turns (default false)
# PERSONA_FRONTIER_COST_VERIFIED_AT_DEPLOY=false     # D-13-3 — set false when costs
#                                                     # are best-estimate (e.g., NVIDIA
#                                                     # hosted catalog — no public
#                                                     # $/Mtok per R-20-4). Default true.

# Optional: where the runtime writes per-turn TurnLog JSONL (D-05-10).
# Defaults to <PERSONA_CHROMA_PATH>/turnlogs/<conversation_id>.jsonl (mirrors the
# audit-log path convention). max_tool_rounds is a constructor default (5);
# no env knob in v0.1 (D-05-11). Likewise the agentic loop's max_steps is a
# constructor default (20); no env knob in v0.1 (spec 06, D-06-7).
# PERSONA_TURNLOG_PATH=.chroma/turnlogs/

# Spec 25 T21 (§2.9 RISKY half) — refusal auto-retry guardrail. DEFAULT-OFF.
# When the model REFUSES a tool it actually has (e.g. "I can't generate images"
# while generate_image is wired), the turn loop can inject ONE corrective system
# message ("You DO have the X tool…") and re-generate once. OFF by default —
# the runtime only DETECTS + records refusals (TurnLog.tool_refusal_detected)
# unless this is explicitly armed. Set to 1/true/yes/on to enable; logs
# TurnLog.refusal_retry_engaged per turn. Experimental: the corrected text
# streams after the refusal (visible self-correction).
# PERSONA_REFUSAL_RETRY_ENABLED=false

# --- HF local backend (only with persona-core[local] extras) ---
# PERSONA_LOCAL_MODEL_ID=google/gemma-2-9b-it
# PERSONA_LOCAL_QUANTIZATION=4bit          # 4bit | 8bit | none
# PERSONA_LOCAL_DEVICE=auto                # auto | cuda | mps | cpu

# --- ChromaDB (local dev) ---
PERSONA_CHROMA_PATH=.chroma/

# --- Postgres (hosted) ---
# Sync psycopg3 dialect (D-07-1): the MemoryStore protocol is synchronous, so
# the persona-core Postgres transport uses sync psycopg3. The spec-08 API may
# add its own async engine separately.
# Host port the docker-compose Postgres binds (container side is always 5432).
# Defaults to 5432; override (e.g. 5436) if another Postgres already owns 5432.
# Keep DATABASE_URL's host port in sync with this value.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql+psycopg://persona:persona@localhost:5432/persona

# --- Tools (spec 03) ---
# Web search provider — Brave (default), Tavily, or SerpAPI. (D-03-9, D-03-10)
# Stubs for Tavily/SerpAPI raise NotImplementedError in v0.1.
PERSONA_WEB_SEARCH_PROVIDER=brave
PERSONA_WEB_SEARCH_API_KEY=...

# Optional: per-call truncation cap for web_fetch (default 4000). (D-03-3)
# The model can override per-call; this is informational only — read by the tool, not configured.
# PERSONA_WEB_FETCH_MAX_CHARS=4000

# Sandbox root for file_read/file_write (D-03-23). Defaults to CWD-relative.
PERSONA_TOOLS_SANDBOX_ROOT=./.persona_work

# MCP servers: comma-separated name=url pairs (D-03-22). For EXTERNAL,
# bring-your-own MCP servers (the operator runs them; Persona ships no code).
# Each URL must be http:// or https://; the SDK negotiates Streamable HTTP (D-03-19).
# PERSONA_MCP_SERVERS=husleietvistutvalget=https://mcp.example.no/mcp,timekeeper=https://tk.example.com/mcp

# --- Built-in MCP servers (spec 27) ---
# Persona ships built-in MCP servers as thin FastMCP Streamable-HTTP subprocesses,
# bound to 127.0.0.1 only and spawned LAZILY (only when a persona actually uses one;
# D-27-3). Authored built-ins: time / calculator / filesystem (default-enabled) +
# weather (opt-in). fetch + github are NOT authored — configure them as external
# servers via PERSONA_MCP_SERVERS (D-27-11: the official fetch server has an
# unpatched SSRF CVE; github has an official remote endpoint + OAuth).
#
# Which authored built-ins to enable (comma-separated). UNSET → the safe subset
# time,calculator,filesystem (D-27-4). "" → opt out of all. "Enabled" means
# "available", NOT "running" — lazy spawn starts a server on first use.
# PERSONA_MCP_BUILTIN_ENABLED=time,calculator,filesystem,weather
#
# Optional POSIX uid the built-in MCP subprocesses drop to at spawn (D-27-12).
# UNSET (default) → children inherit the API process user; in production the API
# container runs as the non-root persona user (uid 1000), so its children do too.
# Set this only when the API itself runs as root and must drop privileges.
# PERSONA_MCP_BUILTIN_UID=1000
#
# The 'weather' built-in uses open-meteo (no key). Its free tier is
# NON-COMMERCIAL; a commercial deployment needs a paid open-meteo key or met.no
# (D-27-6). The 'github' EXTERNAL server expects a standard GitHub token (D-27-5):
# GITHUB_TOKEN=ghp_...

# --- Bring-your-own MCP credential encryption (spec 30) ---
# Encrypts user-supplied BYO MCP-server credentials at rest (Fernet/MultiFernet,
# D-30-4). One or more COMMA-SEPARATED url-safe-base64 Fernet keys — the FIRST
# encrypts, ALL decrypt (zero-downtime rotation: prepend a new key, re-encrypt,
# drop the old). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED to save a BYO MCP server that carries auth (a bearer token); unset →
# such a save fails loud (never stores a secret in plaintext). Never logged.
# MCP_CREDENTIAL_KEY=

# --- Docker MCP Gateway (connect-only) ---
# Point the runtime at an externally-run Docker MCP Gateway and EVERY enabled
# server's tools become available through ONE connection — "enable once in Docker,
# then opt each persona in" (per-persona allow-list still gates: a persona only sees
# gateway tools it lists as mcp:docker:<tool>). CONNECT-ONLY: Persona connects, it
# never spawns the gateway (no Docker socket). The URL MUST be the gateway's
# STREAMABLE-HTTP endpoint — run it `--transport streaming --port <p>` and use the
# `/mcp` path (NOT the legacy `sse` transport). Operator deployment config (same trust
# tier as DATABASE_URL → not SSRF-pinned). Unset → no gateway source.
# PERSONA_DOCKER_MCP_GATEWAY_URL=http://127.0.0.1:8811/mcp
#
# Optional bearer for a NON-loopback gateway (a loopback gateway needs none). A
# secret: never logged, rides the Authorization header only — never a prompt/audit.
# PERSONA_DOCKER_MCP_GATEWAY_TOKEN=
#
# Cloud (PERSONA_EDITION=cloud) only: a cloud gateway is shared across tenants and
# must be operator-VETTED. With a gateway URL set, cloud REFUSES to start unless this
# acknowledges the vetted-shared posture (per-tenant gateways / container-running /
# per-user secret injection are deferred). Ignored in community (your own gateway).
# PERSONA_ALLOW_CLOUD_GATEWAY=1
#
# Populate the apps catalog (the ~300-server mirror of github.com/docker/mcp-registry)
# with the OFFLINE sync — never fetched at request time; absent → the built-in catalog:
#   uv run python -c "from pathlib import Path; from persona.tools.mcp.mirror_sync import sync_mirror; import persona.tools.mcp.mirror as m; sync_mirror(mirror_path=m.MIRROR_PATH)"

# --- Docker MCP catalog auto-sync (Spec N2) ---
# Keep the catalog mirror FRESH automatically: a leader-gated periodic task in the worker
# loop re-pulls github.com/docker/mcp-registry on a daily-ish cadence and reconciles the
# mirror (adds new servers, updates changed, marks removed). Availability updates
# automatically; ENABLING stays the per-persona allow-list (it never auto-enables).
#
# Where the auto-synced mirror is written + read. The bundled package-data mirror.json is
# baked into the image (root-owned, lost on redeploy), so the auto-sync writes to a path on
# the mounted persistent volume instead; the request-path loader PREFERS this over the
# bundled snapshot (precedence: this override -> bundled mirror.json -> built-in catalog).
# Unset (dev/local) -> the bundled snapshot is used and is also the sync's write target.
# In the hosted deploy set it under the mounted volume (e.g. /var/lib/persona/mcp/mirror.json).
# PERSONA_MCP_MIRROR_PATH=/var/lib/persona/mcp/mirror.json
#
# Opt-out switch for the periodic auto-sync (default true). false -> no periodic outbound
# git clone; availability stays at whatever the bundled snapshot provides (fail-soft).
# PERSONA_MCP_SYNC_ENABLED=true
#
# Auto-sync cadence in seconds (default 86400 = daily). The Docker catalog changes slowly,
# so one shallow clone/day from one process is plenty (and rate-limit-friendly).
# PERSONA_MCP_SYNC_INTERVAL_SECONDS=86400

# --- Skills (spec 04) ---
# TOKEN_BUDGET is a module constant (2000); no env knob in v0.1 (D-04-7,
# architecture §5.1.2 "non-negotiable"). User skills live in `skills/`
# alongside the persona YAML; absent directory silently skipped (D-04-5).

# --- Logging ---
PERSONA_LOG_LEVEL=INFO
# PERSONA_LOG_FORMAT=pretty                # pretty | json
# PERSONA_LOG_FILE=/var/log/persona.log

# --- Spec 12 hosted sandbox (D-12-12 E2B — CONFIRMED via five lock-gates) ---
# Hosted sandbox substrate per D-12-12. E2B Hobby tier (free; $100 starter
# credit; no payment information required) at https://e2b.dev/. The SDK reads
# E2B_API_KEY natively — no extra wiring in our HostedSandbox adapter (T08).
# All five lock-gates ✅ PASS — see docs/specs/phase2/spec_12/audit/.
# **Install the SDK:** `uv pip install -e packages/api[hosted]` (pulls
# `e2b-code-interpreter>=1.0,<2`). The api package boots cleanly without the
# extra (lazy-import at use-site); only required when `E2B_API_KEY` is set.
# E2B_API_KEY=e2b_...

# --- Spec 12 T09 sandbox pool (D-12-17 locked configuration) ---
# Pool defaults read at api process startup via Pydantic Settings. v0.1 ships
# warm-pool=0 (lazy-eager prewarm on first acquire) — set nonzero only after
# D-12-17's warm-pool flip-trigger fires (production telemetry signal).
# PERSONA_SANDBOX_WARM_POOL_SIZE=0           # v0.1 locked to 0 by validator
# PERSONA_SANDBOX_REAP_INTERVAL_S=60         # background reaper sweep cadence
# PERSONA_SANDBOX_IDLE_TIMEOUT_S=300         # session staleness before reap
# PERSONA_SANDBOX_MAX_PER_USER=2             # per-tenant concurrent-session cap

# --- Spec 13 workspace (image uploads + Spec 15 generated images + Spec 16/17 sandbox produced files) ---
# Per-deployment workspace root. Every upload + generated image + produced
# file lands under <workspace_root>/<owner_id>/<persona_id>/... — RLS-scoped
# via the persona pre-flight on every route. Defaults to a .persona_work
# directory under the API process's CWD so a clean checkout boots without
# env setup. Set in production to a persistent volume.
# PERSONA_API_WORKSPACE_ROOT=./.persona_work

# --- LLM-assisted persona authoring (drafter) sampling ---
# The FIRST draft / refinement generation samples at these values so persona
# NAMES + personality come out distinctive and varied (not bland-greedy). The
# schema validation-repair RETRY is always deterministic (temperature 0.0) so
# raising creativity never weakens schema compliance. Tunable without redeploy.
# Temperature is the primary lever (default 0.9). top_p / top_k are optional —
# unset leaves the provider default untouched. top_p is honoured by OpenAI +
# Anthropic; top_k only by Anthropic / hf_local / ollama (NO-OP on OpenAI). The
# default authoring tier is Anthropic (PERSONA_FRONTIER_PROVIDER), so top_k DOES
# reach the model.
# PERSONA_API_AUTHORING_TEMPERATURE=0.9
# PERSONA_API_AUTHORING_TOP_P=0.95
# PERSONA_API_AUTHORING_TOP_K=60

# --- Spec 14 document ingestion ---
# PDF page rasterisation DPI for scanned-PDF VISION_HANDOFF (R-14-2 + D-14-2 sub).
# Default 150 (sweet spot for OCR-readable text); valid range 100–300.
# Operators tune up for fine-print legal documents; tune down for cost.
# PERSONA_DOC_PDF_RASTER_DPI=150

# --- Spec 15 image generation (PERSONA_IMAGEGEN_* — env_prefix on ImageBackendConfig) ---
# Image generation is OFF by default — the API boots cleanly without these,
# but every POST /v1/personas/:id/imagegen returns 503 ImageGenUnavailableError
# until PERSONA_IMAGEGEN_API_KEY is set (the startup WARNING you see is the
# fail-fast surface). Set provider + model + key to enable.
#
# Operator hint (Spec 19 amendment, 2026-06-07): when PERSONA_IMAGEGEN_API_KEY
# is provisioned post-deploy, re-run F4 Journey 1 (the image-generation
# walkthrough at packages/web/e2e/f4-rich-output.spec.ts) — it flips from
# 🟦 PARTIAL (skipped on missing key) to ✅ PASS once the key resolves. See
# docs/specs/phase2/spec_F4/closeout.md "External smoke" + the Spec 15 §5
# cross-spec ledger editorial note for the full operator-pass procedure.
#
# Provider lock per D-15-1 + Spec 20 (nvidia) + Spec 22 (openrouter) +
# Spec 25 D-25-11..14 (cloudflare): openai | fal | nvidia | openrouter | cloudflare.
#
# RECOMMENDED DEFAULT (Spec 25 D-25-13): Cloudflare Workers AI — the only
# truly-free path. A free Cloudflare account gives 10,000 neurons/day
# (~170–230 flux-1-schnell images/day), no card required. flux-1-schnell is
# GA (stable pricing). It has NO width/height/guidance/negative_prompt knobs
# and a fixed output size — switch to OpenAI/fal (below) if you need those or
# higher fidelity. account_id is a SEPARATE var (D-25-12), not in the base URL.
# PERSONA_IMAGEGEN_PROVIDER=cloudflare
# PERSONA_IMAGEGEN_MODEL=@cf/black-forest-labs/flux-1-schnell
# PERSONA_IMAGEGEN_API_KEY=          # Cloudflare API token (Workers AI Read+Edit)
# PERSONA_IMAGEGEN_CLOUDFLARE_ACCOUNT_ID=   # 32-char hex, from the CF dashboard
#
# NOTE — two config FORMS for Cloudflare:
#   (a) Single-provider (triplet, above): account_id = PERSONA_IMAGEGEN_CLOUDFLARE_ACCOUNT_ID.
#   (b) Cross-provider MODELS list (PERSONA_IMAGEGEN_MODELS=cloudflare/@cf/...): the API key
#       resolves via the per-provider PERSONA_CLOUDFLARE_API_KEY, and the account_id via
#       PERSONA_CLOUDFLARE_ACCOUNT_ID (the imagegen-prefixed name is also accepted as a fallback).
#   Cloudflare allow-set (D-25-11): @cf/black-forest-labs/flux-1-schnell (GA, primary),
#   @cf/stabilityai/stable-diffusion-xl-base-1.0 (beta), @cf/lykon/dreamshaper-8-lcm (beta).
#
# PREMIUM-QUALITY ALTERNATIVE: openai (gpt-image-1.x — supports size/quality
# knobs; paid) | fal (Flux 1.1 [pro] via fal-client; paid). NVIDIA image gen
# is Enterprise-tier only (Spec 25 §2.10) — not a free option.
# PERSONA_IMAGEGEN_PROVIDER=openai
# PERSONA_IMAGEGEN_MODEL=gpt-image-1
# PERSONA_IMAGEGEN_API_KEY=sk-...
#
# Optional: override the provider's default base URL (proxy / self-hosted).
# PERSONA_IMAGEGEN_BASE_URL=https://api.openai.com/v1
#
# Optional: per-call HTTP timeout (seconds). Default 120.0; conservative
# upper bound that still surfaces dead-provider cases via ImageProviderError.
# PERSONA_IMAGEGEN_REQUEST_TIMEOUT_S=120.0
#
# Optional: fal.ai per-call safety_tolerance (1 strict – 6 permissive).
# Default 2 (fal API default, conservative end per D-15-X-provider-moderation-default).
# Ignored when PERSONA_IMAGEGEN_PROVIDER=openai.
# PERSONA_IMAGEGEN_FAL_SAFETY_TOLERANCE=2
#
# fal-client SDK reads FAL_KEY natively. ImageBackendConfig.api_key is the
# source of truth; the fal backend sets FAL_KEY in os.environ around the
# call and restores prior value after — no need to set FAL_KEY directly
# unless integrating with another tool that reads it.
# FAL_KEY=...

# --- Spec V2 streaming STT (PERSONA_STT_* — env_prefix on StreamingSTTConfig) ---
# Streaming STT is OFF by default — the voice loop falls back to V1's
# PassThroughEchoMode.ECHO until PERSONA_STT_API_KEY is set. With STT off,
# voice calls do not transcribe; V4/V5 turn-taking + persona model wiring
# wait for STT enablement.
#
# Operator hint (Phase-3 critic gate corrections, 2026-06-07): Deepgram
# streaming PAYG is $0.0048/min ($0.0042/min Growth); $0.0077/min is for
# pre-recorded transcription, NOT streaming. $200 signup credit covers
# Phase 5 prototype validation. PAYG concurrency cap is 150 streams
# (Feb 2026 tripling); v0.1 advisory-lock (D-V1-5) caps per-user to 1
# active call, so per-user STT spend = avg-call-duration * per-minute rate.
#
# Provider lock per D-V2-1: deepgram (Nova-3 Monolingual Streaming for
# Norwegian/Swedish/English; Nova-3 Multilingual for Arabic — one quality
# tier below; falsification triggers route to speechmatics behind same
# StreamingSTT Protocol seam). speechmatics is the documented alternative
# behind the Protocol; whisper-streaming is v0.2 cost-reduction candidate.
# PERSONA_STT_PROVIDER=deepgram
# PERSONA_STT_MODEL=nova-3
# PERSONA_STT_API_KEY=...
#
# Optional: override the provider's default base URL (proxy / self-hosted).
# PERSONA_STT_BASE_URL=https://api.deepgram.com
#
# Optional: per-call HTTP request timeout (seconds). Default 60.0.
# PERSONA_STT_REQUEST_TIMEOUT_S=60.0
#
# Optional: language hint forwarded to provider (overrides per-persona
# identity.language_default). Use ISO 639-1 codes: en / no / sv / ar.
# Per-session override possible via VoiceConfig wiring.
# PERSONA_STT_LANGUAGE_HINT=en
#
# Optional: speech-activity VAD library. Default silero per
# D-V2-X-silero-implementation-shape (ONNX-only path; MIT; bundled weights
# via silero-vad-lite — no torch transitive).
# PERSONA_STT_VAD_LIBRARY=silero
#
# Optional: Deepgram endpointing silence (ms before is_final=true on
# transcript message). Default 300; raise toward 500 for more conservative
# turn-end detection.
# PERSONA_STT_DEEPGRAM_ENDPOINTING_MS=300
#
# Optional: Deepgram UtteranceEnd silence (ms before UtteranceEnd event;
# independent from endpointing). Default 1000.
# PERSONA_STT_DEEPGRAM_UTTERANCE_END_MS=1000
#
# Optional: Silero speech-onset confirmation window (ms). Default 50
# (R-V2-2 wall-clock budget: typical 85-90 ms onset; worst-case
# 116-121 ms including SileroFramer; T12 measurement gates verify).
# PERSONA_STT_SILERO_MIN_SPEECH_DURATION_MS=50
#
# Optional: Silero silence-confirmation window (ms before speech_ended).
# Default 200; raise toward 600 for natural turn-end.
# PERSONA_STT_SILERO_MIN_SILENCE_DURATION_MS=200
#
# Optional: Silero activation threshold (0.0-1.0). Default 0.5; raise
# toward 0.7-0.8 in noisy environments (R-V2-2 + LiveKit production data
# show ~51 % FP rate untuned in conversational audio — V4 semantic
# turn-detector overlay is the load-bearing defense).
# PERSONA_STT_SILERO_ACTIVATION_THRESHOLD=0.5
#
# Optional: suppress Silero speech_started while the persona is speaking
# (the no-AEC TTS-mute stopgap). Default FALSE — a hard mute blocks a real
# barge-in onset, so the persona can't be interrupted while speaking AND the
# user's barge-in audio is withheld from the billed STT stream until it
# finishes (D-V8-X-bargein-during-speech-fix). Browser/transport AEC + the
# orchestrator confidence/confirm rejection are the real echo defense. Set
# TRUE only on a deployment proven to lack AEC.
# PERSONA_STT_SILERO_ECHO_MUTE_WHILE_SPEAKING=false

# --- Spec V3 streaming TTS (PERSONA_TTS_* — env_prefix on StreamingTTSConfig) ---
# Streaming TTS is OFF by default — the voice loop produces no synthesised
# speech until PERSONA_TTS_API_KEY is set. With TTS off, V5's reply text is
# not voiced; the outbound rail stays silent (or echoes in V1 pass-through).
#
# Cost discipline (D-V3-X-cost): TTS is the SECOND continuously-metered
# service on top of V2 STT (~0.48 cents/min) and the LLM (per-token) — a
# voice call meters three services every second. Cartesia is ~1 credit/char,
# effective ~ $0.023/min (~ 2.3 cents/min) on the Startup tier; assume
# worst-case 2x overage until published rates are confirmed. Per-session
# spend is logged in VoiceLog.tts_total_cents (T11) and verified at the T14
# external smoke. MAINTENANCE.md tracks the compounded STT+TTS+LLM quarterly
# cost-cadence review.
#
# Provider lock per D-V3-1: cartesia (Sonic 3.5 — WebSocket contexts API;
# native raw PCM16 mono 24 kHz; sub-90 ms first-audio; 42 langs incl.
# Norwegian/Swedish/Arabic; per-context cancel for V4 barge-in). elevenlabs
# (Flash v2.5) is the documented alternative behind the same StreamingTTS
# Protocol seam (falsification triggers route to it — EU TTFA, Nordic
# quality, or cost).
# PERSONA_TTS_PROVIDER=cartesia
# PERSONA_TTS_MODEL=sonic-3.5
# PERSONA_TTS_API_KEY=...
#
# Optional: override the provider's default base URL (proxy / self-hosted).
# PERSONA_TTS_BASE_URL=https://api.cartesia.ai
#
# Optional: per-call HTTP/WebSocket request timeout (seconds). Default 60.0.
# PERSONA_TTS_REQUEST_TIMEOUT_S=60.0
#
# Optional: default catalogue voice id (D-V3-4) used when a persona has no
# explicit identity.voice. Without it, a voice-less persona fails resolution
# with TTSVoiceNotFoundError. Browse the catalogue via the backend's
# list_voices (D-V3-3) to pick an id.
# PERSONA_TTS_VOICE_DEFAULT=...
#
# Chunking knobs (D-V3-2 — hybrid sentence-level + first-chunk-shorter). The
# rule-based chunker emits a short first chunk for fast time-to-first-audio,
# then sentence-level chunks for prosody. Defaults are the locked values; T14
# tunes against real first-audio latency.
# PERSONA_TTS_CHUNK_MIN_FIRST_CHARS=10
# PERSONA_TTS_CHUNK_MAX_FIRST_WORDS=30
# PERSONA_TTS_CHUNK_MIN_CHARS=20
# PERSONA_TTS_CHUNK_MAX_CHARS=300
#
# Optional: pinned Cartesia API-contract date (D-V3-1). Default 2026-03-01.
# PERSONA_TTS_CARTESIA_VERSION=2026-03-01
#
# Optional: Cartesia server-side text buffer (ms, 0-5000). Default 0 — the
# client chunker is load-bearing (D-V3-X-chunker-placement), so the provider
# buffer is zeroed to avoid double-buffering (chunking happens exactly once).
# PERSONA_TTS_CARTESIA_MAX_BUFFER_DELAY_MS=0

# --- Spec 32 greet-first turn-0 bounds (PERSONA_VOICE_* — env_prefix on VoiceConfig) ---
#
# The persona answers the phone: the call rings until turn 0 (the greeting) is
# ready, then it speaks first. These knobs bound that opening so a call never
# rings forever (D-32-3). Defaults are the researched degrade ladder.
#
# How long turn 0 waits on the shared embedder warm-up before proceeding (s);
# the ring covers the rest of any remaining cold load (D-32-X-warmup-gates-turn0).
# PERSONA_VOICE_GREET_WARMUP_TIMEOUT_S=10.0
#
# How long the call may ring with no greeting audio before degrading to the
# user's floor (s) — the agent-side "never ring forever" bound.
# PERSONA_VOICE_GREET_TIMEOUT_S=30.0

# --- Spec A0: durable execution — the worker service (persona_api.jobs) ---
#
# The worker is a SEPARATE long-lived process from the api (run it as its own
# Fly process / container: `python -m persona_api.worker` once the entrypoint is
# wired at deploy). It claims durable jobs from Postgres and runs them with
# crash-resume + retry. All knobs are optional; defaults shown.
#
# The worker's CROSS-TENANT dispatch engine DSN — claim/heartbeat/complete on the
# jobs tables only. Empty → falls back to DATABASE_URL (superuser) for v0.1. Point
# at a least-privilege `job_dispatcher` role (BYPASSRLS, granted on jobs/
# jobs_archive ONLY) to harden — pure config, no code change.
# WORKER_DISPATCH_DATABASE_URL=postgresql+psycopg://job_dispatcher:...@host/db
#
# WORKER_CONCURRENCY=4                      # async jobs in flight per worker process
# WORKER_POLL_INTERVAL_SECONDS=1.0          # base claim-poll interval
# WORKER_POLL_JITTER_SECONDS=0.5            # + U(0, jitter) so N workers don't thunder
# WORKER_CLAIM_LEASE_SECONDS=90             # bootstrap lease; per-job-type heartbeat extends it
# WORKER_DRAIN_SECONDS=270                  # graceful-drain budget; MUST be < Fly kill_timeout (300)
# WORKER_MAX_JOBS_PER_USER=3                # claim-time fairness cap (anti-starvation)
# WORKER_MAX_JOBS_GLOBAL=0                  # total in-flight cap; 0 = unlimited
# WORKER_MAINTENANCE_INTERVAL_SECONDS=30    # rescuer + cleaner + retention sweep cadence
# WORKER_ARCHIVE_AFTER_SECONDS=86400        # age terminal jobs into jobs_archive after this
# WORKER_ARCHIVE_RETENTION_SECONDS=2592000  # purge archive rows older than this (30 days)
#
# Cutover flag (orchestrator flips at deploy): route avatar generation through the
# durable queue instead of the in-process BackgroundTasks path. Default off keeps
# the create contract (POST → avatar_url=null, appears on a later GET).
# PERSONA_API_AVATAR_VIA_QUEUE=0

# --- Spec A1: scheduling — the scheduler tick (hosted in the worker) ---
# The tick is a single-leader poller inside the worker (leadership via a Postgres
# advisory lock — only one worker ticks at a time). It claims due schedules and
# materialises each into an A0 job keyed by schedule_id+fire_time (effectively-once).
# All config-driven (D-A1-2/D-A1-3); defaults shown.
# PERSONA_SCHEDULER_TICK_INTERVAL_SECONDS=30       # how often the leader ticks (jittered by the loop)
# PERSONA_SCHEDULER_BATCH_SIZE=100                  # max due schedules materialised per tick
# Missed-fire policy windows (a fire is "missed" when the worker was down across it):
# PERSONA_SCHEDULER_ON_TIME_TOLERANCE_SECONDS=120  # within this lateness → fire normally (caught promptly)
# PERSONA_SCHEDULER_DEFAULT_GRACE_SECONDS=10800     # recurring fire-late-once catch-up window (3h); per-schedule override
# PERSONA_SCHEDULER_ONE_TIME_GRACE_SECONDS=3600     # one-time fire-late-once catch-up window (1h)
# Beyond grace (or skip-and-note) → skip + a durable miss note; never burst-replay.

# --- The autonomous task model (Spec A2) -----------------------------------
# A task spans days through many bounded legs. These knobs are config-driven defaults the
# worker composition injects; the in-code defaults match the values below.
# PERSONA_TASK_CHECKPOINT_TOKEN_BUDGET=2000     # cap on the checkpoint's accumulating core (conclusions/decisions/lessons); overflow → reflect-and-compact, else CheckpointTooLargeError
# PERSONA_TASK_LEG_WALLCLOCK_SECONDS=180        # per-leg wall-clock bound — must sit inside the worker drain (≥30s margin below 270s)
# PERSONA_TASK_LEG_MAX_STEPS=10                 # per-leg step bound (below the chat loop's 20)
# PERSONA_TASK_LEG_BUDGET_MICROS=               # optional per-leg spend cap (amount_micros); empty = no cap (steps + wall-clock still bound)
# PERSONA_TASK_RECENT_LEG_SUMMARIES=3           # last-N leg summaries in reconstruction (max 5)
# PERSONA_TASK_WORKSPACE_RETENTION_DAYS=7       # how long a terminal task's Spec-12 workspace survives before destroy

# --- Connectors: reach your persona on chat apps (Specs C1/C2/C3) -----------
# The `persona-connectors` service (`python -m persona_connectors`, a separate process that
# reuses the api chat flow + C0 delivery) makes a persona reachable in chat-app DMs. A
# platform is wired iff its bot token is set; configured platforms run concurrently. All
# tokens are SecretStr — never logged. Idle conversations end after a tunable gap.
# PERSONA_CONNECTORS_IDLE_TIMEOUT_MINUTES=30
# Cloud edition shares the api DB (same persona_app role, RLS-scoped per inbound owner):
# PERSONA_CONNECTORS_DATABASE_URL=postgresql+psycopg://persona_app:...@host:5432/persona

# Telegram (Spec C2): the bot-token + deep-link carrier; webhook (prod) or long-poll (dev).
# PERSONA_CONNECTORS_TELEGRAM_BOT_TOKEN=         # @BotFather token (required to run Telegram)
# PERSONA_CONNECTORS_TELEGRAM_TRANSPORT=longpoll # longpoll (dev, zero-infra) | webhook (prod)
# PERSONA_CONNECTORS_TELEGRAM_WEBHOOK_SECRET=    # constant-time-validated before parsing (webhook)
# PERSONA_CONNECTORS_TELEGRAM_WEBHOOK_URL=       # public HTTPS endpoint (webhook mode)
# PERSONA_CONNECTORS_TELEGRAM_BOT_USERNAME=      # for the t.me deep link (else resolved via getMe)

# Discord (Spec C3): a DM adapter over the gateway (WebSocket inbound) + OAuth identity link.
# DM-ability needs a mutual guild / user-install — the identify+bot consent establishes it.
# PERSONA_CONNECTORS_DISCORD_BOT_TOKEN=          # bot token (required to run Discord); rides in the Authorization header
# PERSONA_CONNECTORS_DISCORD_OAUTH_CLIENT_ID=    # OAuth2 app client id (identity linking)
# PERSONA_CONNECTORS_DISCORD_OAUTH_CLIENT_SECRET=
# PERSONA_CONNECTORS_DISCORD_OAUTH_REDIRECT_URI= # the registered OAuth callback URL
# PERSONA_CONNECTORS_DISCORD_LINK_TOKEN_TTL_MINUTES=15

# Slack (Spec C3): a DM adapter; DMs are unconditional once installed. Default transport is
# SOCKET MODE (an outbound WS — no public endpoint, the xapp app-token authenticates it).
# PERSONA_CONNECTORS_SLACK_BOT_TOKEN=            # xoxb-… bot token (required to run Slack)
# PERSONA_CONNECTORS_SLACK_TRANSPORT=socket      # socket (default, zero-infra) | http (public signed endpoint)
# PERSONA_CONNECTORS_SLACK_APP_TOKEN=            # xapp-… app-level token (REQUIRED for socket mode)
# PERSONA_CONNECTORS_SLACK_SIGNING_SECRET=       # v0= HMAC signing secret (REQUIRED for http-events mode)
# PERSONA_CONNECTORS_SLACK_OAUTH_CLIENT_ID=      # OAuth v2 app client id (identity linking)
# PERSONA_CONNECTORS_SLACK_OAUTH_CLIENT_SECRET=
# PERSONA_CONNECTORS_SLACK_OAUTH_REDIRECT_URI=
# PERSONA_CONNECTORS_SLACK_LINK_TOKEN_TTL_MINUTES=15

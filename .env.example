# Copy to .env and fill in your values. Never commit .env.
#
# Spec 02 (model backends): persona-core reads PERSONA_PROVIDER + PERSONA_API_KEY
# + PERSONA_MODEL (+ optional PERSONA_BASE_URL) for the default backend.
# Optional per-tier overrides land in spec 05; the keys below reserve the env var
# names so the wiring is consistent across specs.

# --- Default backend (used by CLI and as the frontier tier in spec 05) ---
PERSONA_PROVIDER=anthropic
PERSONA_MODEL=claude-sonnet-4-6
PERSONA_API_KEY=sk-ant-...

# Optional: override the provider's default base URL (proxy, self-hosted, or a
# new provider not in the OpenAI-compat table).
# PERSONA_BASE_URL=https://my-proxy.example/v1/

# Optional: per-call HTTP timeout (seconds). Default 60. (D-02-3)
# PERSONA_REQUEST_TIMEOUT_S=60

# Optional: have the CLI load .env into os.environ on startup (D-02-4).
# Library code never touches .env autoload; only the CLI sets this.
# PERSONA_DOTENV_LOAD=1

# --- Per-provider keys (used when a tier picks a non-default provider) ---
# (Provider-key env vars are read by spec 05's router, not by spec 02.)
# PERSONA_ANTHROPIC_API_KEY=sk-ant-...
# PERSONA_OPENAI_API_KEY=sk-...
# PERSONA_DEEPSEEK_API_KEY=sk-...
# PERSONA_GROQ_API_KEY=gsk_...
# PERSONA_TOGETHER_API_KEY=...
# PERSONA_OLLAMA_BASE_URL=http://localhost:11434

# --- Tier overrides (spec 05 router; read by TierRegistry) ---
# The runtime routes each turn to frontier / mid / small (architecture §5.3).
# Fallback (D-05-3): an unconfigured tier falls back small → mid → frontier.
# If NONE of the tier triples below are set, the registry builds a single
# backend from PERSONA_PROVIDER/PERSONA_MODEL/PERSONA_API_KEY above and serves
# it for all three tiers. If nothing resolves, TierNotConfiguredError (fail-fast).
PERSONA_FRONTIER_PROVIDER=anthropic
PERSONA_FRONTIER_MODEL=claude-sonnet-4-6
PERSONA_FRONTIER_API_KEY=sk-ant-...

PERSONA_MID_PROVIDER=deepseek
PERSONA_MID_MODEL=deepseek-chat
PERSONA_MID_API_KEY=sk-...

PERSONA_SMALL_PROVIDER=groq
PERSONA_SMALL_MODEL=llama-3.1-8b-instant
PERSONA_SMALL_API_KEY=gsk_...

# Optional: where the runtime writes per-turn TurnLog JSONL (D-05-10).
# Defaults to <PERSONA_CHROMA_PATH>/turnlogs/<conversation_id>.jsonl (mirrors the
# audit-log path convention). max_tool_rounds is a constructor default (5);
# no env knob in v0.1 (D-05-11). Likewise the agentic loop's max_steps is a
# constructor default (20); no env knob in v0.1 (spec 06, D-06-7).
# PERSONA_TURNLOG_PATH=.chroma/turnlogs/

# --- HF local backend (only with persona-core[local] extras) ---
# PERSONA_LOCAL_MODEL_ID=google/gemma-2-9b-it
# PERSONA_LOCAL_QUANTIZATION=4bit          # 4bit | 8bit | none
# PERSONA_LOCAL_DEVICE=auto                # auto | cuda | mps | cpu

# --- ChromaDB (local dev) ---
PERSONA_CHROMA_PATH=.chroma/

# --- Postgres (hosted) ---
# Sync psycopg3 dialect (D-07-1): the MemoryStore protocol is synchronous, so
# the persona-core Postgres transport uses sync psycopg3. The spec-08 API may
# add its own async engine separately.
DATABASE_URL=postgresql+psycopg://persona:persona@localhost:5432/persona

# --- Tools (spec 03) ---
# Web search provider — Brave (default), Tavily, or SerpAPI. (D-03-9, D-03-10)
# Stubs for Tavily/SerpAPI raise NotImplementedError in v0.1.
PERSONA_WEB_SEARCH_PROVIDER=brave
PERSONA_WEB_SEARCH_API_KEY=...

# Optional: per-call truncation cap for web_fetch (default 4000). (D-03-3)
# The model can override per-call; this is informational only — read by the tool, not configured.
# PERSONA_WEB_FETCH_MAX_CHARS=4000

# Sandbox root for file_read/file_write (D-03-23). Defaults to CWD-relative.
PERSONA_TOOLS_SANDBOX_ROOT=./.persona_work

# MCP servers: comma-separated name=url pairs (D-03-22).
# Each URL must be http:// or https://; the SDK negotiates Streamable HTTP (D-03-19).
# PERSONA_MCP_SERVERS=husleietvistutvalget=https://mcp.example.no/mcp,timekeeper=https://tk.example.com/mcp

# --- Skills (spec 04) ---
# TOKEN_BUDGET is a module constant (2000); no env knob in v0.1 (D-04-7,
# architecture §5.1.2 "non-negotiable"). User skills live in `skills/`
# alongside the persona YAML; absent directory silently skipped (D-04-5).

# --- Logging ---
PERSONA_LOG_LEVEL=INFO
# PERSONA_LOG_FORMAT=pretty                # pretty | json
# PERSONA_LOG_FILE=/var/log/persona.log

# --- Spec 12 hosted sandbox (D-12-12 E2B — CONFIRMED via five lock-gates) ---
# Hosted sandbox substrate per D-12-12. E2B Hobby tier (free; $100 starter
# credit; no payment information required) at https://e2b.dev/. The SDK reads
# E2B_API_KEY natively — no extra wiring in our HostedSandbox adapter (T08).
# All five lock-gates ✅ PASS — see docs/specs/phase2/spec_12/audit/.
# **Install the SDK:** `uv pip install -e packages/api[hosted]` (pulls
# `e2b-code-interpreter>=1.0,<2`). The api package boots cleanly without the
# extra (lazy-import at use-site); only required when `E2B_API_KEY` is set.
# E2B_API_KEY=e2b_...

# --- Spec 12 T09 sandbox pool (D-12-17 locked configuration) ---
# Pool defaults read at api process startup via Pydantic Settings. v0.1 ships
# warm-pool=0 (lazy-eager prewarm on first acquire) — set nonzero only after
# D-12-17's warm-pool flip-trigger fires (production telemetry signal).
# PERSONA_SANDBOX_WARM_POOL_SIZE=0           # v0.1 locked to 0 by validator
# PERSONA_SANDBOX_REAP_INTERVAL_S=60         # background reaper sweep cadence
# PERSONA_SANDBOX_IDLE_TIMEOUT_S=300         # session staleness before reap
# PERSONA_SANDBOX_MAX_PER_USER=2             # per-tenant concurrent-session cap

# --- Spec 13 workspace (image uploads + Spec 15 generated images + Spec 16/17 sandbox produced files) ---
# Per-deployment workspace root. Every upload + generated image + produced
# file lands under <workspace_root>/<owner_id>/<persona_id>/... — RLS-scoped
# via the persona pre-flight on every route. Defaults to a .persona_work
# directory under the API process's CWD so a clean checkout boots without
# env setup. Set in production to a persistent volume.
# PERSONA_API_WORKSPACE_ROOT=./.persona_work

# --- Spec 14 document ingestion ---
# PDF page rasterisation DPI for scanned-PDF VISION_HANDOFF (R-14-2 + D-14-2 sub).
# Default 150 (sweet spot for OCR-readable text); valid range 100–300.
# Operators tune up for fine-print legal documents; tune down for cost.
# PERSONA_DOC_PDF_RASTER_DPI=150

# --- Spec 15 image generation (PERSONA_IMAGEGEN_* — env_prefix on ImageBackendConfig) ---
# Image generation is OFF by default — the API boots cleanly without these,
# but every POST /v1/personas/:id/imagegen returns 503 ImageGenUnavailableError
# until PERSONA_IMAGEGEN_API_KEY is set (the startup WARNING you see is the
# fail-fast surface). Set provider + model + key to enable.
#
# Provider lock per D-15-1: openai (gpt-image-1.x, demo-primary per
# D-15-X-demo-primary-provider) | fal (Flux 1.1 [pro] via fal-client).
# PERSONA_IMAGEGEN_PROVIDER=openai
# PERSONA_IMAGEGEN_MODEL=gpt-image-1
# PERSONA_IMAGEGEN_API_KEY=sk-...
#
# Optional: override the provider's default base URL (proxy / self-hosted).
# PERSONA_IMAGEGEN_BASE_URL=https://api.openai.com/v1
#
# Optional: per-call HTTP timeout (seconds). Default 120.0; conservative
# upper bound that still surfaces dead-provider cases via ImageProviderError.
# PERSONA_IMAGEGEN_REQUEST_TIMEOUT_S=120.0
#
# Optional: fal.ai per-call safety_tolerance (1 strict – 6 permissive).
# Default 2 (fal API default, conservative end per D-15-X-provider-moderation-default).
# Ignored when PERSONA_IMAGEGEN_PROVIDER=openai.
# PERSONA_IMAGEGEN_FAL_SAFETY_TOLERANCE=2
#
# fal-client SDK reads FAL_KEY natively. ImageBackendConfig.api_key is the
# source of truth; the fal backend sets FAL_KEY in os.environ around the
# call and restores prior value after — no need to set FAL_KEY directly
# unless integrating with another tool that reads it.
# FAL_KEY=...
